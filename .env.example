# ============================================================
# ImageKit Media Manager — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# Your ImageKit URL Endpoint
# (ImageKit Dashboard → Developer Options → URL Endpoint)
# Example: https://ik.imagekit.io/your_imagekit_id
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Your ImageKit Public Key
# (ImageKit Dashboard → Developer Options → Public key)
VITE_IMAGEKIT_PUBLIC_KEY=your_public_key

# Your ImageKit Private Key
# (ImageKit Dashboard → Developer Options → Private key)
# ⚠️  This is used for delete/rename/tag operations from the frontend.
# Because the app is password-protected for personal/internal use, this is acceptable.
# Do NOT share the built JS bundle publicly if you are security-conscious.
VITE_IMAGEKIT_PRIVATE_KEY=your_private_key

# Admin password to unlock the Upload/Edit/Delete features
# Use a strong password (min 8 chars, mix of letters/numbers)
VITE_ADMIN_PASSWORD=your_admin_password
